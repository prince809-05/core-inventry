// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("user")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  otpTokens   OtpToken[]
  receipts    Receipt[]
  deliveries  Delivery[]
  transfers   Transfer[]
  adjustments Adjustment[]
}

model OtpToken {
  id        String   @id @default(cuid())
  userId    String
  token     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  categoryId  String
  unit        String   @default("pcs")
  reorderQty  Int      @default(10)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category      Category       @relation(fields: [categoryId], references: [id])
  stockLevels   StockLevel[]
  receiptLines  ReceiptLine[]
  deliveryLines DeliveryLine[]
  transferLines TransferLine[]
  adjustments   Adjustment[]
  stockMoves    StockMove[]
}

model Warehouse {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  address   String?
  createdAt DateTime   @default(now())

  locations Location[]
}

model Location {
  id          String    @id @default(cuid())
  warehouseId String
  name        String
  code        String
  createdAt   DateTime  @default(now())

  warehouse         Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  stockLevels       StockLevel[]
  deliveryLines     DeliveryLine[]
  transferLinesFrom TransferLine[] @relation("TransferFrom")
  transferLinesTo   TransferLine[] @relation("TransferTo")
  adjustments       Adjustment[]
  stockMovesFrom    StockMove[]    @relation("MoveFrom")
  stockMovesTo      StockMove[]    @relation("MoveTo")

  @@unique([warehouseId, code])
}

model StockLevel {
  id         String   @id @default(cuid())
  productId  String
  locationId String
  qty        Int      @default(0)
  updatedAt  DateTime @updatedAt

  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([productId, locationId])
}

model Receipt {
  id         String        @id @default(cuid())
  reference  String        @unique
  supplier   String
  status     ReceiptStatus @default(DRAFT)
  notes      String?
  userId     String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  validatedAt DateTime?

  user  User          @relation(fields: [userId], references: [id])
  lines ReceiptLine[]
}

enum ReceiptStatus {
  DRAFT
  WAITING
  READY
  DONE
  CANCELED
}

model ReceiptLine {
  id         String  @id @default(cuid())
  receiptId  String
  productId  String
  qty        Int
  locationId String?

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Delivery {
  id          String         @id @default(cuid())
  reference   String         @unique
  customer    String
  status      DeliveryStatus @default(DRAFT)
  notes       String?
  userId      String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  validatedAt DateTime?

  user  User           @relation(fields: [userId], references: [id])
  lines DeliveryLine[]
}

enum DeliveryStatus {
  DRAFT
  READY
  DONE
  CANCELED
}

model DeliveryLine {
  id         String  @id @default(cuid())
  deliveryId String
  productId  String
  locationId String
  qty        Int

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])
}

model Transfer {
  id          String         @id @default(cuid())
  reference   String         @unique
  status      TransferStatus @default(DRAFT)
  notes       String?
  userId      String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  validatedAt DateTime?

  user  User           @relation(fields: [userId], references: [id])
  lines TransferLine[]
}

enum TransferStatus {
  DRAFT
  READY
  DONE
  CANCELED
}

model TransferLine {
  id             String  @id @default(cuid())
  transferId     String
  productId      String
  fromLocationId String
  toLocationId   String
  qty            Int

  transfer     Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id])
  fromLocation Location @relation("TransferFrom", fields: [fromLocationId], references: [id])
  toLocation   Location @relation("TransferTo", fields: [toLocationId], references: [id])
}

model Adjustment {
  id          String   @id @default(cuid())
  reference   String   @unique
  productId   String
  locationId  String
  physicalQty Int
  previousQty Int
  difference  Int
  reason      String
  userId      String
  createdAt   DateTime @default(now())

  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
}

enum StockMoveType {
  RECEIPT
  DELIVERY
  TRANSFER
  ADJUSTMENT
}

model StockMove {
  id          String        @id @default(cuid())
  type        StockMoveType
  reference   String
  productId   String
  fromLocId   String?
  toLocId     String?
  qtyChange   Int
  qtyBefore   Int
  qtyAfter    Int
  userId      String
  createdAt   DateTime      @default(now())

  product  Product   @relation(fields: [productId], references: [id])
  fromLoc  Location? @relation("MoveFrom", fields: [fromLocId], references: [id])
  toLoc    Location? @relation("MoveTo", fields: [toLocId], references: [id])
}
