# Environment variables for CoreInventory Backend

# Database
DATABASE_URL=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# Email (for OTP password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=

# OTP
OTP_EXPIRES_MINUTES=10
